{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@slkiser/opencode-quota"],
  "permission": {
    "external_directory": {
      "/tmp/**": "allow"
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "excalidraw": {
      "type": "local",
      "command": [
        "/home/d3adb0y/.config/nvm/versions/node/v22.22.2/bin/node",
        "/home/d3adb0y/mcp/mcp_excalidraw/dist/index.js"
      ],
      "environment": {
        "EXPRESS_SERVER_URL": "http://localhost:3000"
      },
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp/oauth",
      "enabled": true
    }
  }
}
